{
  "name": "operational-memory-mvp",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm --workspace @ops-memory/web run dev",
    "dev:api": "npm --workspace @ops-memory/api run dev",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "test:web": "tsx --test --test-concurrency=1 apps/web/src/lib/*.test.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "prisma": "^7.5.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0"
  }
}
